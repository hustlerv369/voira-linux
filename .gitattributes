# Normalize line endings — LF in repo, CRLF only in working copy on Windows checkout.
* text=auto eol=lf

# Shell scripts and CI workflows must stay LF (run on Linux runners).
*.sh text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
PKGBUILD text eol=lf
.SRCINFO text eol=lf
*.desktop text eol=lf

# Binary assets — never touch.
*.png binary
*.AppImage binary
*.deb binary
*.rpm binary
